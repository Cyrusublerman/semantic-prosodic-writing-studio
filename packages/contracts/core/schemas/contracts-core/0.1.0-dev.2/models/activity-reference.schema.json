{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "ActivityId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "AgentId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "AgentReference": {
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "$ref": "#/$defs/AgentId"
        },
        "agent_type": {
          "$ref": "#/$defs/AgentType"
        },
        "display_name": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "external_identifiers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalIdentifier"
          },
          "title": "External Identifiers",
          "type": "array"
        },
        "version": {
          "anyOf": [
            {
              "maxLength": 255,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "agent_id",
        "agent_type"
      ],
      "title": "AgentReference",
      "type": "object"
    },
    "AgentType": {
      "enum": [
        "person",
        "organisation",
        "software_component",
        "model",
        "service",
        "system"
      ],
      "title": "AgentType",
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ProcessingState": {
      "enum": [
        "pending",
        "running",
        "awaiting_human",
        "succeeded",
        "partially_succeeded",
        "failed",
        "cancelled",
        "timed_out",
        "blocked",
        "skipped"
      ],
      "title": "ProcessingState",
      "type": "string"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "RunId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "StepRunId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "UtcDateTime": {
      "format": "date-time",
      "type": "string",
      "x-spws-timezone": "UTC"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:activity-reference:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "activity_id": {
      "$ref": "#/$defs/ActivityId"
    },
    "activity_type": {
      "title": "Activity Type",
      "type": "string"
    },
    "component_version": {
      "anyOf": [
        {
          "maxLength": 255,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Component Version"
    },
    "ended_at": {
      "anyOf": [
        {
          "$ref": "#/$defs/UtcDateTime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "parameters_digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parameters Digest"
    },
    "responsible_agents": {
      "items": {
        "$ref": "#/$defs/AgentReference"
      },
      "title": "Responsible Agents",
      "type": "array"
    },
    "run_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunId"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "started_at": {
      "$ref": "#/$defs/UtcDateTime"
    },
    "status": {
      "$ref": "#/$defs/ProcessingState"
    },
    "step_run_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/StepRunId"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "activity_id",
    "activity_type",
    "status",
    "started_at",
    "responsible_agents"
  ],
  "title": "ActivityReference",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
