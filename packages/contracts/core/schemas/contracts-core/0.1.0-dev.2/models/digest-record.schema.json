{
  "$defs": {
    "CanonicalisationMethod": {
      "enum": [
        "none",
        "unicode_profile",
        "rfc8785_jcs",
        "domain_projection"
      ],
      "title": "CanonicalisationMethod",
      "type": "string"
    },
    "CanonicalisationRecord": {
      "additionalProperties": false,
      "properties": {
        "method": {
          "$ref": "#/$defs/CanonicalisationMethod"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "method"
      ],
      "title": "CanonicalisationRecord",
      "type": "object"
    },
    "DigestAlgorithm": {
      "enum": [
        "sha-256"
      ],
      "title": "DigestAlgorithm",
      "type": "string"
    },
    "DigestBasis": {
      "enum": [
        "raw_bytes",
        "utf8_text",
        "jcs_json",
        "record_projection"
      ],
      "title": "DigestBasis",
      "type": "string"
    },
    "VerificationState": {
      "enum": [
        "unverified",
        "verified",
        "mismatch"
      ],
      "title": "VerificationState",
      "type": "string"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:digest-record:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "algorithm": {
      "$ref": "#/$defs/DigestAlgorithm",
      "default": "sha-256"
    },
    "basis": {
      "$ref": "#/$defs/DigestBasis"
    },
    "byte_length": {
      "minimum": 0,
      "title": "Byte Length",
      "type": "integer"
    },
    "canonicalisation": {
      "anyOf": [
        {
          "$ref": "#/$defs/CanonicalisationRecord"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "character_encoding": {
      "anyOf": [
        {
          "maxLength": 64,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Character Encoding"
    },
    "media_type": {
      "anyOf": [
        {
          "maxLength": 255,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Media Type"
    },
    "value": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Value",
      "type": "string"
    },
    "verification_state": {
      "$ref": "#/$defs/VerificationState",
      "default": "unverified"
    }
  },
  "required": [
    "value",
    "basis",
    "byte_length"
  ],
  "title": "DigestRecord",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
