{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ObjectId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "VersionId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:object-reference:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "external_identifiers": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExternalIdentifier"
      },
      "title": "External Identifiers",
      "type": "array"
    },
    "object_id": {
      "$ref": "#/$defs/ObjectId"
    },
    "object_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "uri": {
      "anyOf": [
        {
          "$ref": "#/$defs/AbsoluteUri"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "version_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/VersionId"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "object_id"
  ],
  "title": "ObjectReference",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
