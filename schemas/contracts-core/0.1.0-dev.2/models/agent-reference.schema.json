{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "AgentId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "AgentType": {
      "enum": [
        "person",
        "organisation",
        "software_component",
        "model",
        "service",
        "system"
      ],
      "title": "AgentType",
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:agent-reference:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agent_id": {
      "$ref": "#/$defs/AgentId"
    },
    "agent_type": {
      "$ref": "#/$defs/AgentType"
    },
    "display_name": {
      "anyOf": [
        {
          "maxLength": 512,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Display Name"
    },
    "external_identifiers": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExternalIdentifier"
      },
      "title": "External Identifiers",
      "type": "array"
    },
    "version": {
      "anyOf": [
        {
          "maxLength": 255,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Version"
    }
  },
  "required": [
    "agent_id",
    "agent_type"
  ],
  "title": "AgentReference",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
