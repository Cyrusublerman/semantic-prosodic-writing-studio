{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "ActivityId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ObjectId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "ObjectReference": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "external_identifiers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalIdentifier"
          },
          "title": "External Identifiers",
          "type": "array"
        },
        "object_id": {
          "$ref": "#/$defs/ObjectId"
        },
        "object_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/RegisteredIdentifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/VersionId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "object_id"
      ],
      "title": "ObjectReference",
      "type": "object"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "RelationId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "ReviewState": {
      "enum": [
        "unreviewed",
        "machine_checked",
        "human_reviewed",
        "approved",
        "rejected",
        "disputed",
        "superseded"
      ],
      "title": "ReviewState",
      "type": "string"
    },
    "VersionId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "VersionReference": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "object_id": {
          "$ref": "#/$defs/ObjectId"
        },
        "object_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/RegisteredIdentifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version_id": {
          "$ref": "#/$defs/VersionId"
        }
      },
      "required": [
        "object_id",
        "version_id"
      ],
      "title": "VersionReference",
      "type": "object"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:provenance-relation:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "activity_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/ActivityId"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "entity_role": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Entity Role"
    },
    "method": {
      "anyOf": [
        {
          "maxLength": 512,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Method"
    },
    "object": {
      "anyOf": [
        {
          "$ref": "#/$defs/VersionReference"
        },
        {
          "$ref": "#/$defs/ObjectReference"
        }
      ],
      "title": "Object"
    },
    "parameters_digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parameters Digest"
    },
    "relation_id": {
      "$ref": "#/$defs/RelationId"
    },
    "relation_type": {
      "title": "Relation Type",
      "type": "string"
    },
    "review_state": {
      "$ref": "#/$defs/ReviewState",
      "default": "unreviewed"
    },
    "source_span_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Source Span Ids",
      "type": "array"
    },
    "subject": {
      "$ref": "#/$defs/VersionReference"
    },
    "target_span_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Target Span Ids",
      "type": "array"
    }
  },
  "required": [
    "relation_id",
    "relation_type",
    "subject",
    "object"
  ],
  "title": "ProvenanceRelation",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
