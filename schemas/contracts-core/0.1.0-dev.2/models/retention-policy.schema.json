{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "DeletionMode": {
      "enum": [
        "hard_delete_payload",
        "tombstone_only",
        "cryptographic_erasure",
        "external_reference_removal",
        "blocked_by_hold"
      ],
      "title": "DeletionMode",
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ObjectId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "ObjectReference": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "external_identifiers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalIdentifier"
          },
          "title": "External Identifiers",
          "type": "array"
        },
        "object_id": {
          "$ref": "#/$defs/ObjectId"
        },
        "object_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/RegisteredIdentifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/VersionId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "object_id"
      ],
      "title": "ObjectReference",
      "type": "object"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "session",
        "project_lifetime",
        "until_date",
        "indefinite",
        "legal_hold",
        "delete_on_request"
      ],
      "title": "RetentionClass",
      "type": "string"
    },
    "UtcDateTime": {
      "format": "date-time",
      "type": "string",
      "x-spws-timezone": "UTC"
    },
    "VersionId": {
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:retention-policy:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "delete_after": {
      "anyOf": [
        {
          "$ref": "#/$defs/UtcDateTime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "deletion_mode": {
      "$ref": "#/$defs/DeletionMode"
    },
    "hold_reference": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObjectReference"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "legal_hold": {
      "default": false,
      "title": "Legal Hold",
      "type": "boolean"
    },
    "notes": {
      "anyOf": [
        {
          "maxLength": 2048,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    }
  },
  "required": [
    "retention_class",
    "deletion_mode"
  ],
  "title": "RetentionPolicy",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
