{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "SemVer": {
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "type": "string"
    }
  },
  "$id": "urn:pkl:spws:schema:contracts-core:schema-reference:0.1.0-dev.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Schema Digest"
    },
    "schema_id": {
      "$ref": "#/$defs/AbsoluteUri"
    },
    "schema_version": {
      "$ref": "#/$defs/SemVer"
    }
  },
  "required": [
    "schema_id",
    "schema_version"
  ],
  "title": "SchemaReference",
  "type": "object",
  "x-spws-release": "0.1.0-dev.2"
}
