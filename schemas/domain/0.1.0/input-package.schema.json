{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ObjectId": {
      "format": "uuid",
      "type": "string"
    },
    "ObjectReference": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "external_identifiers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalIdentifier"
          },
          "title": "External Identifiers",
          "type": "array"
        },
        "object_id": {
          "$ref": "#/$defs/ObjectId"
        },
        "object_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/RegisteredIdentifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/VersionId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "object_id"
      ],
      "title": "ObjectReference",
      "type": "object"
    },
    "PrivacyState": {
      "enum": [
        "public",
        "internal",
        "sensitive",
        "private",
        "unknown"
      ],
      "title": "PrivacyState",
      "type": "string"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "RightsState": {
      "enum": [
        "public",
        "internal",
        "restricted",
        "private",
        "unknown"
      ],
      "title": "RightsState",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "fatal"
      ],
      "title": "Severity",
      "type": "string"
    },
    "UtcDateTime": {
      "format": "date-time",
      "type": "string",
      "x-spws-timezone": "UTC"
    },
    "VersionId": {
      "format": "uuid",
      "type": "string"
    },
    "WarningId": {
      "format": "uuid",
      "type": "string"
    },
    "WarningRecord": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "related_objects": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ObjectReference"
          },
          "title": "Related Objects",
          "type": "array"
        },
        "remediation": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "scope": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "warning_id": {
          "$ref": "#/$defs/WarningId"
        }
      },
      "required": [
        "warning_id",
        "code",
        "name",
        "severity",
        "scope"
      ],
      "title": "WarningRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Material entering the system without interpretation.",
  "properties": {
    "bytes_location": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bytes Location"
    },
    "capture_route": {
      "default": "direct_text",
      "title": "Capture Route",
      "type": "string"
    },
    "captured_at": {
      "$ref": "#/$defs/UtcDateTime"
    },
    "creator": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Creator"
    },
    "encoding": {
      "default": "utf-8",
      "title": "Encoding",
      "type": "string"
    },
    "media_type": {
      "default": "text/plain",
      "title": "Media Type",
      "type": "string"
    },
    "package_id": {
      "title": "Package Id",
      "type": "string"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyState",
      "default": "unknown"
    },
    "requested_operations": {
      "items": {
        "type": "string"
      },
      "title": "Requested Operations",
      "type": "array"
    },
    "retention_policy": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retention Policy"
    },
    "rights": {
      "$ref": "#/$defs/RightsState",
      "default": "unknown"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Label"
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text"
    },
    "user_metadata": {
      "additionalProperties": true,
      "title": "User Metadata",
      "type": "object"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/WarningRecord"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "package_id",
    "captured_at"
  ],
  "title": "InputPackage",
  "type": "object"
}
