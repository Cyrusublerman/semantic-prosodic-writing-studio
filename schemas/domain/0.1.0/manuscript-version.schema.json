{
  "$defs": {
    "UtcDateTime": {
      "format": "date-time",
      "type": "string",
      "x-spws-timezone": "UTC"
    }
  },
  "additionalProperties": false,
  "properties": {
    "manuscript_id": {
      "title": "Manuscript Id",
      "type": "string"
    },
    "version_id": {
      "title": "Version Id",
      "type": "string"
    },
    "text": {
      "title": "Text",
      "type": "string"
    },
    "parent_version_ids": {
      "items": {
        "type": "string"
      },
      "title": "Parent Version Ids",
      "type": "array"
    },
    "accepted_change_ids": {
      "items": {
        "type": "string"
      },
      "title": "Accepted Change Ids",
      "type": "array"
    },
    "unresolved_alternatives": {
      "items": {
        "type": "string"
      },
      "title": "Unresolved Alternatives",
      "type": "array"
    },
    "work_plan_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Work Plan Id"
    },
    "created_at": {
      "$ref": "#/$defs/UtcDateTime"
    },
    "provenance_map": {
      "additionalProperties": true,
      "title": "Provenance Map",
      "type": "object"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "manuscript_id",
    "version_id",
    "text",
    "created_at"
  ],
  "title": "ManuscriptVersion",
  "type": "object"
}
