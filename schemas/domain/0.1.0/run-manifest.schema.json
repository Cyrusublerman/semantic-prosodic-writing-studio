{
  "$defs": {
    "AbsoluteUri": {
      "type": "string"
    },
    "ExternalIdentifier": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "$ref": "#/$defs/RegisteredIdentifier"
        },
        "resolution_state": {
          "$ref": "#/$defs/ResolutionState",
          "default": "unresolved"
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "value"
      ],
      "title": "ExternalIdentifier",
      "type": "object"
    },
    "ObjectId": {
      "format": "uuid",
      "type": "string"
    },
    "ObjectReference": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "external_identifiers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalIdentifier"
          },
          "title": "External Identifiers",
          "type": "array"
        },
        "object_id": {
          "$ref": "#/$defs/ObjectId"
        },
        "object_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/RegisteredIdentifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsoluteUri"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/VersionId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "object_id"
      ],
      "title": "ObjectReference",
      "type": "object"
    },
    "ReadMode": {
      "enum": [
        "snapshot",
        "working_tree",
        "remote"
      ],
      "title": "ReadMode",
      "type": "string"
    },
    "RegisteredIdentifier": {
      "type": "string"
    },
    "ResolutionState": {
      "enum": [
        "unresolved",
        "resolved",
        "unavailable",
        "invalid"
      ],
      "title": "ResolutionState",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "fatal"
      ],
      "title": "Severity",
      "type": "string"
    },
    "UtcDateTime": {
      "format": "date-time",
      "type": "string",
      "x-spws-timezone": "UTC"
    },
    "VersionId": {
      "format": "uuid",
      "type": "string"
    },
    "WarningId": {
      "format": "uuid",
      "type": "string"
    },
    "WarningRecord": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "related_objects": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ObjectReference"
          },
          "title": "Related Objects",
          "type": "array"
        },
        "remediation": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "scope": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "warning_id": {
          "$ref": "#/$defs/WarningId"
        }
      },
      "required": [
        "warning_id",
        "code",
        "name",
        "severity",
        "scope"
      ],
      "title": "WarningRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "commit_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Commit Sha"
    },
    "component_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Component Versions",
      "type": "object"
    },
    "finished_at": {
      "anyOf": [
        {
          "$ref": "#/$defs/UtcDateTime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "input_refs": {
      "items": {
        "type": "string"
      },
      "title": "Input Refs",
      "type": "array"
    },
    "output_refs": {
      "items": {
        "type": "string"
      },
      "title": "Output Refs",
      "type": "array"
    },
    "parameters": {
      "additionalProperties": true,
      "title": "Parameters",
      "type": "object"
    },
    "pipeline_id": {
      "title": "Pipeline Id",
      "type": "string"
    },
    "read_mode": {
      "$ref": "#/$defs/ReadMode"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "started_at": {
      "$ref": "#/$defs/UtcDateTime"
    },
    "status": {
      "default": "running",
      "title": "Status",
      "type": "string"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/WarningRecord"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "run_id",
    "pipeline_id",
    "started_at",
    "read_mode"
  ],
  "title": "RunManifest",
  "type": "object"
}
