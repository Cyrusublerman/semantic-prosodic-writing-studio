{
  "$defs": {
    "StructuralScope": {
      "enum": [
        "work",
        "section",
        "paragraph",
        "stanza",
        "sentence",
        "line",
        "phrase",
        "word",
        "phoneme"
      ],
      "title": "StructuralScope",
      "type": "string"
    },
    "TextSpan": {
      "additionalProperties": false,
      "properties": {
        "start_char": {
          "minimum": 0,
          "title": "Start Char",
          "type": "integer"
        },
        "end_char": {
          "minimum": 0,
          "title": "End Char",
          "type": "integer"
        },
        "start_byte": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Byte"
        },
        "end_byte": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Byte"
        },
        "quote": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote"
        }
      },
      "required": [
        "start_char",
        "end_char"
      ],
      "title": "TextSpan",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "unit_id": {
      "title": "Unit Id",
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/StructuralScope"
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text"
    },
    "span": {
      "anyOf": [
        {
          "$ref": "#/$defs/TextSpan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "parent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Id"
    },
    "child_ids": {
      "items": {
        "type": "string"
      },
      "title": "Child Ids",
      "type": "array"
    },
    "source_object_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Object Id"
    },
    "ordinal": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ordinal"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "unit_id",
    "scope"
  ],
  "title": "StructuralUnit",
  "type": "object"
}
